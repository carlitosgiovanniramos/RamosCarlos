namespace Examen_Primer_Parcial_Software;

class Program
{
    static void Main(string[] args)
    {
        Console.Write("Ingrese tamaño del vector: ");
        if (!int.TryParse(Console.ReadLine(), out int n) || n <= 0)
        {
            Console.WriteLine("Tamaño no válido.");
            return;
        }

        int[] v = new int[n];

        // ingreso de datos
        for (int i = 0; i < n; i++)
        {
            Console.Write($"Ingrese valor [{i}]: ");
            v[i] = int.Parse(Console.ReadLine());
        }

        // Instancia de la clase encargada de la lógica (reutilizable)
        var sorter = new IndexSorter(v);

        // ORDENAMIENTO ASCENDENTE
        int[] ascIndices = sorter.GetAscendingIndices();
        Console.WriteLine("\nVector ordenado ascendente:");
        for (int i = 0; i < n; i++)
        {
            Console.WriteLine(v[ascIndices[i]]);
        }

        // ORDENAMIENTO DESCENDENTE
        int[] descIndices = sorter.GetDescendingIndices();
        Console.WriteLine("\nVector ordenado descendente:");
        for (int i = 0; i < n; i++)
        {
            Console.WriteLine(v[descIndices[i]]);
        }
    }
}

/// <summary>
/// Clase encargada de proveer los índices ordenados de un vector sin modificar  
/// ni copiar sus elementos originales, lista para ser reutilizada en otros entornos.
/// </summary>
public class IndexSorter
{
    private readonly int[] _originalVector;

    public IndexSorter(int[] originalVector)
    {
        _originalVector = originalVector;
    }

    public int[] GetAscendingIndices()
    {
        int[] indices = InitializeIndices();
        // Ordenamos el vector de índices usando los valores originales como referencia
        Array.Sort(indices, (a, b) => _originalVector[a].CompareTo(_originalVector[b]));
        return indices;
    }

    public int[] GetDescendingIndices()
    {
        int[] indices = InitializeIndices();
        // Ordenamos el vector de índices de forma inversa usando los valores originales como referencia
        Array.Sort(indices, (a, b) => _originalVector[b].CompareTo(_originalVector[a]));
        return indices;
    }

    private int[] InitializeIndices()
    {
        int[] indices = new int[_originalVector.Length];
        for (int i = 0; i < indices.Length; i++)
        {
            indices[i] = i;
        }
        return indices;
    }
}

